        "name": "Authentication",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Sign in to a BILL organization",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://gateway.prod.bill.com/connect/v3/login",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Authenticates a BILL user. Returns a `sessionId` to be used as the\nsession identifier on subsequent requests (expires after 35 minutes of\ninactivity).\n"
        },
        {
          "info": {
            "name": "Sign out of the current session",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://gateway.prod.bill.com/connect/v3/logout"
          },
          "docs": "Sign out of the current session"
        },
